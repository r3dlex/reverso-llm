# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# uv
.venv/
# uv.lock is intentionally tracked for reproducibility

# Environment / secrets - never commit
.env
.env.*
*.key

# macOS
.DS_Store

# Logs
*.log

# IDE
.idea/
.vscode/
*.swp
*.swo

# Test artefacts
.pytest_cache/
.coverage
htmlcov/

# OMC runtime state (transient; plans/ and specs/ are tracked)
.omc/state/

# Spike notes are per-machine operational notes, not committed (see docs/04-mvp.md)
docs/spike-notes.md

# Local runtime / backup artifacts
.omc/sessions/
config/*.bak
config/*.bak*
config/*backup

# Operational agent state (transient; never committed)
.agents/
.oma/
# .omc/ mixes transient runtime state with COMMITTED knowledge that source/tests
# depend on (plans/research/specs/context/interviews/handoffs). Ignore the
# transient top-level entries (state, sessions, ultragoal, logs, ...) but keep the
# committed-knowledge directories tracked.
.omc/*
!.omc/context/
!.omc/handoffs/
!.omc/interviews/
!.omc/plans/
!.omc/research/
!.omc/specs/
.omx/
.graphwiki/
graphwiki-out/
