    },
    {
      "name": "get_response",
      "file": "get_response.json",
      "kind": "single",
      "covers": "get_response retrieval"
    },
    {
      "name": "list_input_items",
      "file": "list_input_items.json",
      "kind": "single",
      "covers": "list_input_items"
    },
    {
      "name": "tools_function_call",
      "file": "tools_function_call.json",
